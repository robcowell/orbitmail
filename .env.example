# Optional. Orbit Mail reads OAuth credentials at runtime and never builds them
# into a package, so this file is only a convenience for development — you can
# instead enter them in the Add Account dialog, or put this file at
# ~/.config/orbit-mail/.env for a packaged build. Values here win over both.
#
# Plain IMAP/POP3 accounts need none of this.

# Google OAuth (Desktop app) — https://console.cloud.google.com/
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Microsoft Entra ID — https://portal.azure.com/
MICROSOFT_CLIENT_ID=
MICROSOFT_TENANT_ID=common
