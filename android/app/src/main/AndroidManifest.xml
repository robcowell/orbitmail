<?xml version="1.0" encoding="utf-8"?>
<!--
  The app manifest. Merges the library manifests: :auth:appauth contributes the
  AppAuth redirect receiver (via the appAuthRedirectScheme placeholder set in
  build.gradle.kts), and :background:service contributes the IMAP IDLE foreground
  service + its permissions. This manifest declares the launcher activity, the
  Application, and the mailto handler.
-->
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <application
        android:name=".OrbitApplication"
        android:label="Orbit Mail"
        android:theme="@style/Theme.Material3.DayNight.NoActionBar"
        android:supportsRtl="true">

        <activity
            android:name=".MainActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
            <!-- mailto: handler (audit §IPC) -->
            <intent-filter>
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="mailto" />
            </intent-filter>
        </activity>
    </application>
</manifest>
