{
  "name": "orbit-mail",
  "version": "0.1.0",
  "description": "Orbit Mail — a polished desktop email client for Linux",
  "main": "out/main/index.js",
  "homepage": "https://github.com/orbit-mail/orbit-mail",
  "author": {
    "name": "Orbit Mail",
    "email": "orbit-mail@localhost"
  },
  "license": "MIT",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "icons": "node scripts/generate-icons.mjs",
    "install:desktop": "bash scripts/install-dev-desktop.sh",
    "dist": "npm run icons && npm run build && electron-builder",
    "dist:deb": "npm run icons && npm run build && electron-builder --linux deb",
    "dist:appimage": "npm run icons && npm run build && electron-builder --linux AppImage",
    "postinstall": "electron-builder install-app-deps && bash scripts/install-electron.sh",
    "test:imap": "node scripts/imap-integration.mjs"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.110.0",
    "@azure/msal-node": "^5.3.1",
    "@phosphor-icons/react": "^2.1.10",
    "better-sqlite3": "^12.11.1",
    "dompurify": "^3.2.4",
    "dotenv": "^16.4.7",
    "drizzle-orm": "^0.45.2",
    "google-auth-library": "^9.15.1",
    "imapflow": "^1.0.184",
    "mailparser": "^3.7.2",
    "node-pop3": "^0.11.0",
    "nodemailer": "^9.0.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "virtua": "^0.49.2",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/dompurify": "^3.2.0",
    "@types/mailparser": "^3.4.5",
    "@types/nodemailer": "^6.4.17",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "electron": "^39.8.10",
    "electron-builder": "^26.15.3",
    "electron-vite": "^3.0.0",
    "esbuild": "^0.25.12",
    "sharp": "^0.35.3",
    "typescript": "^5.7.3",
    "vite": "^6.0.11"
  },
  "build": {
    "appId": "com.orbitmail.app",
    "productName": "Orbit Mail",
    "icon": "build/icon.png",
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "files": [
      "out/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "build/icons",
        "to": "icons",
        "filter": [
          "**/*"
        ]
      }
    ],
    "linux": {
      "target": [
        "deb",
        "AppImage"
      ],
      "category": "Network;Email",
      "executableName": "orbit-mail",
      "synopsis": "Desktop email client for Linux",
      "description": "Orbit Mail is a desktop email client with IMAP, SMTP, POP3, and OAuth support.",
      "artifactName": "${productName}-${version}-${os}-${arch}.${ext}",
      "icon": "build/icons",
      "desktop": {
        "entry": {
          "Name": "Orbit Mail",
          "GenericName": "Email Client",
          "Comment": "Desktop email client for Linux with IMAP, SMTP, and OAuth",
          "StartupWMClass": "orbit-mail",
          "Categories": "Network;Email;",
          "MimeType": "x-scheme-handler/mailto;",
          "Keywords": "email;mail;inbox;imap;smtp;gmail;outlook;"
        }
      }
    },
    "deb": {
      "packageName": "orbit-mail",
      "maintainer": "Orbit Mail <orbit-mail@localhost>"
    }
  },
  "overrides": {
    "brace-expansion@1": "^1.1.16",
    "brace-expansion@2": "^2.1.2",
    "uuid": "^11.1.1"
  }
}
